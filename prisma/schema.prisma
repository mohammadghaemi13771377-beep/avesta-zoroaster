generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AvestaSection {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String
  coverImage  String?
  themeColor  String?
  order       Int             @default(0)
  chapters    AvestaChapter[]
  translations AvestaSectionTranslation[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AvestaChapter {
  id          String         @id @default(cuid())
  sectionId   String
  section     AvestaSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  number      Int
  description String?
  coverImage  String?
  order       Int            @default(0)
  verses      AvestaVerse[]
  translations AvestaChapterTranslation[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([sectionId, slug])
}

model AvestaVerse {
  id                    String        @id @default(cuid())
  chapterId             String
  chapter               AvestaChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  originalText           String
  transliteration        String?
  classicalTranslation   String?
  simpleRewrite          String?
  modernInterpretation   String?
  ethicalMessage         String?
  imageUrl               String?
  audioUrl               String?
  order                  Int           @default(0)
  glossaryTerms          GlossaryTerm[] @relation("GlossaryRelatedVerses")
  readingProgress        ReadingProgress[]
  translations           AvestaVerseTranslation[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([chapterId, order])
}

model Article {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  excerpt        String
  content        String
  coverImage     String?
  category       String?
  tags           String[]
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  glossaryTerms  GlossaryTerm[] @relation("GlossaryRelatedArticles")
  translations   ArticleTranslation[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model GlossaryTerm {
  id              String        @id @default(cuid())
  term            String
  slug            String        @unique
  meaning         String
  root            String?
  description     String?
  relatedArticles Article[]     @relation("GlossaryRelatedArticles")
  relatedVerses   AvestaVerse[] @relation("GlossaryRelatedVerses")
  translations     GlossaryTermTranslation[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model LibraryItem {
  id          String   @id @default(cuid())
  title       String
  author      String?
  description String?
  fileUrl     String
  coverImage  String?
  language    String
  type        String
  source      String?
  translations LibraryItemTranslation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([title, language])
}

model MediaAsset {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String
  category    String
  description String
  url         String?
  thumbnail   String?
  prompt      String?
  mood        String?
  accent      String?
  sectionSlug String?
  chapterSlug String?
  verseOrder  Int?
  credit      String?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([sectionSlug, chapterSlug, verseOrder])
}

model ImportJob {
  id           String   @id @default(cuid())
  name         String
  mode         String
  status       String
  contentCount Int      @default(0)
  mediaCount   Int      @default(0)
  failedCount  Int      @default(0)
  payload      Json
  result       Json
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id        String        @id @default(cuid())
  actor     String
  role      UserRole
  action    String
  target    String
  area      String
  severity  AuditSeverity @default(INFO)
  detail    String
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([role])
  @@index([severity])
  @@index([createdAt])
}

model Product {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  category        ProductCategory
  excerpt         String
  description     String
  price           Int
  currency        String          @default("IRR")
  coverImage      String?
  status          ProductStatus   @default(DRAFT)
  inventoryStatus InventoryStatus @default(PREORDER)
  stock           Int             @default(0)
  reservedStock   Int             @default(0)
  lowStockAlert   Int             @default(5)
  materials       String[]
  seoTitle        String?
  seoDescription  String?
  tags            String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  orderItems      OrderItem[]

  @@index([category])
  @@index([status])
}

model Order {
  id              String        @id @default(cuid())
  userId          String?
  email           String
  displayName     String?
  phone           String?
  status          OrderStatus   @default(DRAFT)
  paymentStatus   PaymentStatus @default(PENDING)
  subtotal        Int           @default(0)
  discountCode    String?
  discountTotal   Int           @default(0)
  taxTotal        Int           @default(0)
  total           Int
  currency        String        @default("IRR")
  shippingAddress String?
  shippingMethod  String?
  shippingCost    Int           @default(0)
  notes           String?
  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([paymentStatus])
  @@index([discountCode])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  title     String
  quantity  Int
  unitPrice Int
  total     Int
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String
  authority     String?       @unique
  status        PaymentStatus @default(PENDING)
  amount        Int
  currency      String        @default("IRR")
  callbackUrl   String?
  redirectUrl   String?
  referenceId   String?
  rawResponse   Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([provider])
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier        String?
  method         String
  status         ShipmentStatus @default(PENDING)
  trackingCode   String?
  shippingCost   Int           @default(0)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([trackingCode])
}

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  label       String
  type        CouponType
  amount      Int
  status      CouponStatus @default(ACTIVE)
  startsAt    DateTime?
  expiresAt   DateTime?
  usageLimit  Int?
  usedCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([expiresAt])
}

model AvestaSectionTranslation {
  id          String        @id @default(cuid())
  sectionId   String
  section     AvestaSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  locale      Locale
  title       String
  description String
  seoTitle    String?
  seoDescription String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([sectionId, locale])
}

model AvestaChapterTranslation {
  id          String        @id @default(cuid())
  chapterId   String
  chapter     AvestaChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  locale      Locale
  title       String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([chapterId, locale])
}

model AvestaVerseTranslation {
  id                    String       @id @default(cuid())
  verseId               String
  verse                 AvestaVerse  @relation(fields: [verseId], references: [id], onDelete: Cascade)
  locale                Locale
  originalText           String?
  transliteration        String?
  classicalTranslation   String?
  simpleRewrite          String?
  modernInterpretation   String?
  ethicalMessage         String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([verseId, locale])
}

model ArticleTranslation {
  id             String   @id @default(cuid())
  articleId      String
  article        Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale         Locale
  title          String
  excerpt        String
  content        String
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([articleId, locale])
}

model GlossaryTermTranslation {
  id          String       @id @default(cuid())
  termId      String
  term        GlossaryTerm @relation(fields: [termId], references: [id], onDelete: Cascade)
  locale      Locale
  termText    String
  meaning     String
  root        String?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([termId, locale])
}

model LibraryItemTranslation {
  id          String      @id @default(cuid())
  itemId      String
  item        LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locale      Locale
  title       String
  author      String?
  description String?
  source      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([itemId, locale])
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  displayName       String
  passwordHash      String?
  role              UserRole           @default(READER)
  avatarUrl         String?
  lastLoginAt       DateTime?
  bookmarks         Bookmark[]
  readingProgress   ReadingProgress[]
  readingPreference ReadingPreference?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Bookmark {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  targetType  BookmarkType
  targetUrl   String
  description String?
  createdAt   DateTime     @default(now())

  @@unique([userId, targetUrl])
}

model ReadingProgress {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  verseId    String?
  verse      AvestaVerse?  @relation(fields: [verseId], references: [id], onDelete: SetNull)
  title      String
  targetUrl  String
  progress   Int           @default(0)
  lastReadAt DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([userId, targetUrl])
}

model ReadingPreference {
  id        String      @id @default(cuid())
  userId    String      @unique
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      ReadingMode @default(DARK)
  fontSize  Int         @default(18)
  audio     Boolean     @default(true)
  language  String      @default("fa")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum UserRole {
  READER
  EDITOR
  ADMIN
}

enum BookmarkType {
  AVESTA_VERSE
  ARTICLE
  GLOSSARY_TERM
  HUB
  LIBRARY_ITEM
  MEDIA_ITEM
}

enum ReadingMode {
  DARK
  SEPIA
  LIGHT
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ProductCategory {
  BOOK
  MUG
  SHIRT
  ACCESSORY
  STATUE
  ART
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryStatus {
  AVAILABLE
  PREORDER
  LIMITED
  OUT_OF_STOCK
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  SHIPPED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  PACKING
  SHIPPED
  DELIVERED
  RETURNED
}

enum CouponType {
  PERCENT
  FIXED
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

enum Locale {
  FA
  EN
}
